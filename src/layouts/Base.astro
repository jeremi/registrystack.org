---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Registry Stack | Governed registry services and trusted evidence',
  description =
    'Registry Stack helps public institutions expose protected registry services, return only the evidence a service needs, and audit trust-critical access.',
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://registrystack.org').toString();
const ogImageUrl = new URL('/og-image.png', 'https://registrystack.org').toString();
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID?.trim();
const umamiScriptSrc =
  import.meta.env.PUBLIC_UMAMI_SCRIPT_SRC?.trim() || 'https://stats.registrystack.org/script.js';
const umamiDomains = import.meta.env.PUBLIC_UMAMI_DOMAINS?.trim() || 'registrystack.org';
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Registry Stack" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Registry Stack: prove facts from registries without sharing the records." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      umamiWebsiteId && (
        <script is:inline defer src={umamiScriptSrc} data-website-id={umamiWebsiteId} data-domains={umamiDomains}></script>
      )
    }
  </head>
  <body>
    <slot />
    <script is:inline>
      // Progressive enhancement only: the nav disclosure works without it,
      // and analytics is skipped when Umami is not loaded.
      const journeyTargets = new Map([
        ['docs.registrystack.org', 'docs'],
        ['lab.registrystack.org', 'lab'],
        ['github.com', 'github'],
      ]);

      const textLabel = (node) => (node.textContent || '').replace(/\s+/g, ' ').trim().slice(0, 80);

      const journeyUrl = (anchor, targetSite) => {
        const url = new URL(anchor.href);
        if (targetSite === 'docs' || targetSite === 'lab') {
          url.searchParams.set('utm_source', 'registrystack');
          url.searchParams.set('utm_medium', 'site');
          url.searchParams.set('utm_campaign', 'cross_site');
          url.searchParams.set('utm_content', window.location.pathname);
        }
        return url;
      };

      const trackJourneyClick = (anchor, targetSite) => {
        if (!window.umami?.track) return;
        const url = new URL(anchor.href);
        window.umami.track('marketing_link_click', {
          target_site: targetSite,
          target_path: url.pathname,
          source_path: window.location.pathname,
          link_text: textLabel(anchor),
        });
      };

      document.querySelectorAll('a[href]').forEach((anchor) => {
        try {
          const url = new URL(anchor.href);
          const targetSite = journeyTargets.get(url.hostname);
          if (!targetSite) return;
          anchor.href = journeyUrl(anchor, targetSite).toString();
        } catch (_error) {}
      });

      document.addEventListener('click', (event) => {
        for (const menu of document.querySelectorAll('.nav-group[open]')) {
          if (!menu.contains(event.target)) menu.removeAttribute('open');
        }
        const anchor = event.target instanceof Element ? event.target.closest('a[href]') : null;
        if (!anchor) return;
        try {
          const url = new URL(anchor.href);
          const targetSite = journeyTargets.get(url.hostname) || (url.protocol === 'mailto:' ? 'email' : '');
          if (targetSite) trackJourneyClick(anchor, targetSite);
        } catch (_error) {}
      });
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        for (const menu of document.querySelectorAll('.nav-group[open]')) {
          menu.removeAttribute('open');
        }
      });
    </script>
  </body>
</html>
