---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Registry Stack | Governed registry services and trusted evidence',
  description =
    'Registry Stack helps public institutions expose protected registry services, return only the evidence a service needs, and audit trust-critical access.',
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://registrystack.org').toString();
const ogImageUrl = new URL('/og-image.png', 'https://registrystack.org').toString();
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Registry Stack" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Registry Stack: prove facts from registries without sharing the records." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>
  <body>
    <slot />
    <script is:inline>
      // Progressive enhancement only: the nav disclosure works without it,
      // this just closes it on an outside click or Escape.
      document.addEventListener('click', (event) => {
        for (const menu of document.querySelectorAll('.nav-products[open]')) {
          if (!menu.contains(event.target)) menu.removeAttribute('open');
        }
      });
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        for (const menu of document.querySelectorAll('.nav-products[open]')) {
          menu.removeAttribute('open');
        }
      });
    </script>
  </body>
</html>

