---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import DocsHandoff from '../components/DocsHandoff.astro';

const pageTitle = 'Security | Registry Stack';
const pageDescription =
  'The Registry Stack security model: what a deployment can reach, the controls that contain it, the threat model, and how security is shared with your team.';

// Stated as a trust boundary. A deployment reads the source to answer, so it is
// a sensitive component; the page describes what it can reach and how that is
// contained, in plain reader-facing terms rather than reassurance about itself.
const access = [
  {
    title: 'What a deployment can reach',
    items: [
      'The source fields and records you connect it to, within the scope you configure.',
      'The credentials you give it to read that source.',
      'The audit log it writes about the requests it handles.',
    ],
  },
  {
    title: 'What it is built not to do',
    items: [
      'Act as a data warehouse: it reads to answer and returns a minimized result, not a bulk export.',
      'Return more to a caller than the configured scope allows.',
      'Write back to, or change, the source system; the consultation path is read-only.',
      'Send data to the project: you self-host, and nothing phones home.',
    ],
  },
];

const controls = [
  'Least-privilege source access: connect each deployment with a read-only account scoped to only the fields and records it needs, so even a full compromise is bounded by what that account can read.',
  'One deployment per registry, in that registry’s own environment, so there is no central pool a single breach could drain.',
  'Minimization: a caller receives a fact, a status, or a credential, not a bulk export, so the everyday data surface stays small.',
  'Defense in depth: authentication, scopes, field limits, and audit are separate layers, so one misconfiguration is less likely to expose everything.',
  'Signed, time-bounded answers (Ed25519, SD-JWT VC) a verifier can check, so a forged or stale answer fails verification.',
  'A tamper-evident audit trail on every trust-critical request, so misuse is detectable after the fact.',
];

const threats = [
  {
    title: 'If the service host is compromised',
    body:
      'An attacker could reach the source data that deployment is configured to read, the credentials it uses, and its audit log. A least-privilege source account, network isolation, and secret management keep that reachable surface small and the damage bounded.',
  },
  {
    title: 'If a downstream caller is compromised',
    body:
      'A compromised downstream service still receives only the narrow answer it was granted, never a direct line to the source. This is the case the access controls are designed for, and the one where the exposure is smallest.',
  },
  {
    title: 'If a credential leaks',
    body:
      'Scoped, rotatable credentials and per-request checks limit what a stolen key can do, and the audit trail shows what it was used for. Rotate keys, scope them narrowly, and review the trail.',
  },
];

const outOfScope = [
  'The security of the source system itself stays with the team that runs it.',
  'Establishing who a person is stays with the foundational identity layer.',
  'Whether a request is lawful stays an institutional and legal decision.',
  'Hardening the hosting environment stays with the operator who runs the deployment.',
];

const provides = [
  'Open-source, hardenable software with read-only consultation as the default path.',
  'Signed builds, published posture and audit schemas, and a local self-check.',
  'A hardening checklist in the docs and a coordinated-disclosure process.',
];

const operates = [
  'A least-privilege, read-only source account scoped to only what the service needs.',
  'Hosting hardening, network isolation, TLS termination, secret management, and patching.',
  'Monitoring, key rotation, audit-log protection, and incident response for the deployment.',
  'The legal authority and the policy for who may ask, and for what purpose.',
];

const verify = [
  'The products are open source, so your team and your auditors can review exactly what runs.',
  'Signed builds and the published posture and audit schemas let you confirm what you deploy.',
  'A local self-check validates a deployment against the expected posture.',
  'You can run the whole flow in the hosted lab on synthetic data before any real record is touched.',
];
---

<Base title={pageTitle} description={pageDescription}>
  <SiteHeader current="security" />

  <main>
    <section class="hero" aria-labelledby="security-hero-title">
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Security</p>
          <h1 id="security-hero-title">What Registry Stack can reach, and how that is contained.</h1>
          <p class="hero-lead">
            To answer a question, a deployment reads from your source, within the scope you
            configure. That makes it a sensitive part of your infrastructure, not a neutral pipe.
            What follows is what a deployment can reach, the controls that contain it, the threat
            model, and how security is shared between the project and your team.
          </p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="security-boundary-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow">The trust boundary</p>
          <h2 id="security-boundary-title">Where Registry Stack sits, and what it can touch.</h2>
          <p>
            A deployment is a trusted intermediary between a caller and a source. It has to read
            the source to produce an answer, so the security work is to keep what it can reach
            narrow, and to run it where it can be defended.
          </p>
        </div>
        <div class="security-pair">
          {access.map((group) => (
            <article class="quiet-card">
              <h3>{group.title}</h3>
              <ul class="check-list">
                {group.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-muted" aria-labelledby="security-controls-title">
      <div class="section-inner split">
        <div class="section-heading compact">
          <p class="eyebrow">Bounding the blast radius</p>
          <h2 id="security-controls-title">The controls that limit what a flaw or a breach can reach.</h2>
          <p>
            No control makes a breach impossible. Together they keep the reachable surface small,
            contain a compromise to a single registry, and make misuse detectable after the fact.
          </p>
        </div>
        <ul class="check-list">
          {controls.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section" aria-labelledby="security-threat-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow">Threat model</p>
          <h2 id="security-threat-title">What is at risk in each failure, and how it is bounded.</h2>
          <p>
            The size of the exposure depends on how narrowly the source account is scoped and how
            well the host is run. Each case below names what an attacker could reach, and what
            limits it.
          </p>
        </div>
        <div class="problem-grid">
          {threats.map((item) => (
            <article class="quiet-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
        <div class="split security-scope">
          <div class="section-heading compact">
            <p class="eyebrow">Out of scope</p>
            <h3>What Registry Stack does not secure.</h3>
            <p>
              The following are not part of what Registry Stack secures. They stay with the
              institution and the systems it already runs.
            </p>
          </div>
          <ul class="check-list">
            {outOfScope.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section class="section section-muted" aria-labelledby="security-shared-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow">Shared responsibility</p>
          <h2 id="security-shared-title">Security is a job we split with your team.</h2>
          <p>
            The project ships software that can be operated securely. Running it safely in
            production depends on the deployment, the same way it would for any infrastructure you
            self-host.
          </p>
        </div>
        <div class="security-pair">
          <article class="quiet-card">
            <h3>The project provides</h3>
            <ul class="check-list">
              {provides.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
          <article class="quiet-card">
            <h3>You operate</h3>
            <ul class="check-list">
              {operates.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="security-verify-title">
      <div class="section-inner split">
        <div class="section-heading compact">
          <p class="eyebrow">Verify it yourself</p>
          <h2 id="security-verify-title">You can inspect everything you run.</h2>
          <p>
            Everything a single registry needs is open source and self-hosted, so your team and your
            auditors can review exactly what runs before trusting it.
          </p>
          <a class="inline-cta" href="https://lab.registrystack.org/">Try the live demo on synthetic data &rarr;</a>
        </div>
        <ul class="check-list">
          {verify.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section section-muted" aria-labelledby="security-report-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow">Coordinated disclosure</p>
          <h2 id="security-report-title">Found a security issue? Tell us privately first.</h2>
          <p>
            If you find a vulnerability, please report it privately so it can be fixed before it is
            public. Do not open a public issue for a security report. We will acknowledge your
            report and work with you on a coordinated disclosure.
          </p>
          <p class="security-claim-note">
            Registry Stack does not currently hold a formal security certification. The detailed
            threat model and the current security posture live in the docs, and a pilot includes a
            security review against your own requirements.
          </p>
        </div>
        <div class="solution-choice-row">
          <a class="button button-primary" href="mailto:jeremi@joslin.fr?subject=Registry%20Stack%20security%20report">Report a vulnerability</a>
          <a class="button button-secondary" href="https://docs.registrystack.org/">Read the security docs</a>
        </div>
      </div>
    </section>
  </main>

  <DocsHandoff
    eyebrow="For your security team"
    heading="The detailed threat model, the hardening checklist, and the audit schema live in the docs."
    primaryLabel="Read the security docs"
  />
  <SiteFooter />
</Base>

<style>
  /* Paired cards for the can/cannot, responsibility, and verify sections: a
     balanced two-up that reads as a deliberate comparison. */
  .security-pair {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin-top: clamp(24px, 4vw, 36px);
  }

  .security-pair .quiet-card h3 {
    margin-top: 0;
  }

  /* The out-of-scope split sits inside the threat section, so give it its own
     top rule and spacing rather than the section default. */
  .security-scope {
    border-top: 1px solid var(--registry-rule);
    margin-top: clamp(28px, 4vw, 44px);
    padding: clamp(28px, 4vw, 44px) 0 0;
  }

  .security-claim-note {
    color: var(--registry-muted);
    font-size: 14px;
    margin-top: 14px;
  }

  @media (max-width: 620px) {
    .security-pair {
      grid-template-columns: 1fr;
    }
  }
</style>
