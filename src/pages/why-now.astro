---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import DocsHandoff from '../components/DocsHandoff.astro';

const pageTitle = 'Why now | Registry Stack';
const pageDescription =
  'AI-assisted integration and automation make it cheaper to connect systems than to understand the data. That makes narrow, governed, reviewable registry surfaces more urgent, not less.';

// The review questions from the docs "safer registry surfaces" page, kept as
// the practical shift in what interoperability has to answer.
const reviewQuestions = [
  'Which entity or evidence response is being requested?',
  'Which purpose, policy, and scope apply?',
  'Which fields or claims can leave the source boundary?',
  'Which semantic definition is being used?',
  'Which audit event records the access or evidence decision?',
];
---

<Base title={pageTitle} description={pageDescription}>
  <SiteHeader current="why-now" />

  <main>
    <section class="hero" aria-labelledby="now-hero-title">
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Why now</p>
          <h1 id="now-hero-title">It is cheaper than ever to connect systems faster than you can govern them.</h1>
          <p class="hero-lead">
            AI-assisted integration and automation let teams build connections faster than they
            can understand the data, the authority for access, the disclosure risk, or the
            meaning of each field. That does not make registries an AI problem. It makes the case
            for narrow, governed, reviewable registry surfaces more urgent.
          </p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="urgency-title">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">The shift</p>
          <h2 id="urgency-title">The goal is not to open registries to AI. It is to make registry use explicit for every caller.</h2>
          <p>
            Human teams, exchange layers, workflow engines, and AI-assisted tools all need a
            registry surface to work against, instead of raw files, undocumented tables, broad
            APIs, or copied extracts. Automation makes that need sharper because integrations
            now outpace the review that used to catch problems.
          </p>
        </div>
        <div class="problem-grid">
          <article class="quiet-card">
            <h3>Faster integration, same data risk</h3>
            <p>A generated client can read a broad API and copy a full record in minutes. The disclosure obligation it creates does not shrink because the code was quick to write.</p>
          </article>
          <article class="quiet-card">
            <h3>Controlled answers, not raw records</h3>
            <p>Giving agents and workflows a configured status, predicate, or selected value, rather than a source record, keeps automation inside the line the policy intended.</p>
          </article>
          <article class="quiet-card">
            <h3>Review that can keep up</h3>
            <p>When purpose, scope, and disclosure are enforced at the access point and logged, a reviewer can ask what the system actually accepted, returned, and recorded.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section-muted" aria-labelledby="question-title">
      <div class="section-inner split">
        <div class="section-heading compact">
          <p class="eyebrow">The question shifts</p>
          <h2 id="question-title">From "can these systems connect?" to "is this request legitimate?"</h2>
          <p>
            "Can two systems connect?" is too weak a question for modern interoperability. The
            better question is whether a request is legitimate, scoped, meaningful, minimal, and
            auditable. A registry surface should be able to answer practical review questions.
          </p>
        </div>
        <ul class="check-list">
          {reviewQuestions.map((question) => (
            <li>{question}</li>
          ))}
        </ul>
      </div>
    </section>

    <section class="section" aria-labelledby="not-ai-title">
      <div class="section-inner">
        <div class="section-heading compact">
          <p class="eyebrow">To be clear</p>
          <h2 id="not-ai-title">Registry Stack is not an AI product.</h2>
          <p>
            AI is the context that makes safer surfaces urgent, not the promise. Registry Stack
            does not make AI eligibility decisions, automate governance, or replace semantic
            review, authorization policy, human accountability, appeal, or recourse. It gives
            every caller, human or automated, a controlled answer instead of a raw record.
          </p>
        </div>
      </div>
    </section>
  </main>

  <DocsHandoff
    eyebrow="Read the docs"
    heading="See how policy becomes a runtime check."
    primaryLabel="Read the docs"
  />
  <SiteFooter />
</Base>
