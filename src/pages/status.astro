---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import DocsHandoff from '../components/DocsHandoff.astro';

const pageTitle = 'Status and boundaries | Registry Stack';
const pageDescription =
  'What Registry Stack is today, what it deliberately does not do, and how its parts divide responsibility. An honest read of maturity and scope for funders and technical reviewers.';

// Maturity, framed honestly. These describe surfaces the docs document as built
// today, without claiming production deployments that do not exist.
const builtToday = [
  {
    title: 'Protected read-only routes',
    body: 'Configured CSV, XLSX, Parquet, and PostgreSQL sources can be exposed as authorized entity routes with field projection, caller scopes, and tamper-evident audit records.',
  },
  {
    title: 'Configured evidence responses',
    body: 'Claims can be evaluated against registry sources and returned as a predicate, selected value, or SD-JWT VC credential, with disclosure modes the deployment controls.',
  },
  {
    title: 'Inspectable metadata',
    body: 'A registry can render standards-shaped catalog, schema, policy, and evidence-offering artifacts, and have them inspected before any integration code is written.',
  },
  {
    title: 'A local demo topology',
    body: 'A compose-based lab runs the runtime services together with demo fixtures and credentials, so the model can be exercised end to end before any production work.',
  },
];

// The pitch-form map of the parts and what each does not own, condensed from the
// docs boundaries-and-map reference.
const parts = [
  {
    name: 'Metadata publishing',
    does: 'Compiles a registry’s description into portable, standards-facing artifacts.',
    doesNot: 'Does not serve HTTP, query databases, or hold runtime source configuration.',
  },
  {
    name: 'Protected access',
    does: 'Binds datasets and entities to runtime sources and serves authorized read-only APIs.',
    doesNot: 'Does not perform writes, expose storage table names, or own claim evaluation.',
  },
  {
    name: 'Evidence and credentials',
    does: 'Evaluates configured claims and issues SD-JWT VC credentials with chosen disclosure modes.',
    doesNot: 'Does not decide legal entitlement or produce W3C VC Data Model JSON-LD envelopes.',
  },
  {
    name: 'Inspection',
    does: 'Reads published artifacts and reports candidate routes, gaps, and ambiguities.',
    doesNot: 'Does not prove the source will return production data, or use AI inference to match.',
  },
];

// Pitch-form boundaries, kept aligned with the homepage boundaries section.
const boundaries = [
  'Not a registry replacement.',
  'Not an open-data portal.',
  'Not a national data exchange layer.',
  'Not a workflow engine.',
  'Not a wallet.',
  'Not an AI decision system.',
  'Not a solution to foundational identity, deduplication, legal authority, or institutional approval by itself.',
];
---

<Base title={pageTitle} description={pageDescription}>
  <SiteHeader current="status" />

  <main>
    <section class="hero" aria-labelledby="status-hero-title">
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Status and boundaries</p>
          <h1 id="status-hero-title">An honest read of what exists, and where it stops.</h1>
          <p class="hero-lead">
            Registry Stack is open infrastructure under active development. The surfaces below
            are documented and exercisable today. There are no claimed production integrations
            with named domain platforms; the design is shaped to support them, and that work is
            not yet done. Stating the edges is part of the trust model.
          </p>
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="built-title">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">What is built today</p>
          <h2 id="built-title">Real surfaces, documented and demonstrable.</h2>
          <p>
            Each capability below is documented in the docs and can be run against fixtures. The
            deployment still configures policy, sources, scopes, and disclosure rules.
          </p>
        </div>
        <div class="problem-grid">
          {builtToday.map((item) => (
            <article class="quiet-card">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-muted" aria-labelledby="parts-title">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">How the parts divide</p>
          <h2 id="parts-title">Each part has a narrow job, and a clear list of what it does not own.</h2>
          <p>
            The boundaries between the parts are deliberate. They keep responsibility legible for
            operators and reviewers.
          </p>
        </div>
        <div class="parts-grid">
          {parts.map((part) => (
            <article class="part-card">
              <h3>{part.name}</h3>
              <div class="use-case-field">
                <p class="use-case-label">Owns</p>
                <p class="use-case-text">{part.does}</p>
              </div>
              <div class="use-case-field">
                <p class="use-case-label">Does not own</p>
                <p class="use-case-text">{part.doesNot}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" aria-labelledby="boundaries-title">
      <div class="section-inner">
        <div class="section-heading compact">
          <p class="eyebrow">Boundaries</p>
          <h2 id="boundaries-title">Focused infrastructure, not another whole platform.</h2>
          <p>
            The limits are part of the trust model. Registry Stack is a registry-facing access,
            evidence, metadata, and audit layer.
          </p>
        </div>
        <ul class="boundary-list">
          {boundaries.map((boundary) => (
            <li>{boundary}</li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <DocsHandoff
    eyebrow="Read the docs"
    heading="See the full map and standards evidence."
    primaryLabel="Read the docs"
  />
  <SiteFooter />
</Base>

<style>
  .parts-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .part-card {
    background: #ffffff;
    border: 1px solid var(--registry-rule);
    display: grid;
    gap: 12px;
    min-width: 0;
    padding: 22px;
  }

  .part-card h3 {
    margin: 0;
  }

  @media (max-width: 620px) {
    .parts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
