---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import HeroAnswerCard from '../components/HeroAnswerCard.astro';
import RegistrySeal from '../components/RegistrySeal.astro';

const pageTitle = 'Registry Stack | Governed registry services and trusted evidence';
const pageDescription =
  'Registry Stack helps public institutions expose protected registry APIs and return governed evidence from registries without sharing full records.';

const heroReasons = [
  {
    label: 'Protected access',
    body: 'Expose the registry surface a service is allowed to use, without handing over the source system or its records.',
  },
  {
    label: 'Governed evidence',
    body: 'Return a proof, redacted result, credential, or stable denial after policy, trust, freshness, disclosure, and audit checks.',
  },
  {
    label: 'Inspectable contracts',
    body: 'Publish the metadata, policies, schemas, and evidence offerings partners need before integrations become one-off code.',
  },
];

const heroAnswers = [
  {
    domain: 'Civil registration',
    question: 'Is this person alive?',
    answer: 'Alive · proof of life',
  },
  {
    domain: 'Social protection',
    question: 'Is this household enrolled?',
    answer: 'Enrolled household',
  },
  {
    domain: 'Business registry',
    question: 'Is this supplier actively registered?',
    answer: 'Active',
  },
  {
    domain: 'Farmer registry',
    question: 'Is this a registered farmer, and what is the farm size?',
    answer: 'Registered farmer · 2.5 ha',
  },
];

const solutions = [
  {
    eyebrow: 'Governed evidence exchange',
    title: 'Evidence Gateway',
    body:
      'Use when a service needs a proof, predicate, redacted result, credential, or stable denial from source records it should not receive.',
    href: '/solutions/evidence-gateway/',
    cta: 'Explore Evidence Gateway',
    points: [
      'Policy and trust context checked before evidence is returned.',
      'Freshness, redaction, disclosure, and audit travel with the answer.',
    ],
  },
  {
    eyebrow: 'Safe registry consultation',
    title: 'Protected Registry APIs',
    body:
      'Use when an existing registry source needs read-only routes with authentication, scopes, metadata, field limits, and reviewable audit.',
    href: '/solutions/protected-registry-apis/',
    cta: 'Explore Protected Registry APIs',
    points: [
      'Wrap CSV, XLSX, Parquet, PostgreSQL, extracts, or legacy systems.',
      'Expose entity reads and metadata without opening the database.',
    ],
  },
];

const products = [
  {
    title: 'Registry Notary',
    role: 'Verify',
    body: 'Evaluates governed claims and returns signed answers, attestations, or wallet credentials.',
    href: '/notary/',
  },
  {
    title: 'Registry Relay',
    role: 'Expose',
    body: 'Serves protected, read-only APIs over existing registry files, extracts, and tables.',
    href: '/relay/',
  },
  {
    title: 'Registry Manifest',
    role: 'Describe',
    body: 'Publishes validated metadata, policies, schemas, and evidence offerings.',
    href: '/manifest/',
  },
];

// Neighbor platforms shown as monochrome marks. Display sizes are tuned per
// logo for visual parity, not taken from the source files.
const worksAlongside = [
  { name: 'OpenCRVS', src: '/logos/opencrvs.svg', width: 128, height: 24 },
  { name: 'OpenSPP', src: '/logos/openspp.svg', width: 114, height: 24 },
  { name: 'DHIS2', src: '/logos/dhis2.svg', width: 92, height: 28 },
  { name: 'HL7 FHIR', src: '/logos/fhir.svg', width: 92, height: 30 },
  { name: 'MOSIP', src: '/logos/mosip.png', width: 75, height: 34 },
  { name: 'OpenFn', src: '/logos/openfn.png', width: 81, height: 30 },
];

const proofPoints = [
  {
    title: 'Products with narrow jobs',
    body: 'Inspect the code, run the pieces on your own infrastructure, and compose only the surfaces a deployment needs.',
    fact: 'No product license fees, no vendor gate',
  },
  {
    title: 'A live lab you can use now',
    body: 'The hosted lab issues a real signed proof to a wallet, on synthetic data, and runs integrations with OpenCRVS, DHIS2, MOSIP eSignet, and OpenFn.',
    fact: 'lab.registrystack.org',
  },
  {
    title: 'Standards-shaped outputs',
    body: 'Credentials issue as SD-JWT VC over OpenID4VCI, catalogs render to DCAT-AP, and registry sync follows SP-DCI where that pattern fits.',
    fact: 'SD-JWT VC · OpenID4VCI · no lock-in',
  },
];
---

<Base title={pageTitle} description={pageDescription}>
  <SiteHeader />

  <main>
    <section class="hero hero-cover" aria-labelledby="hero-title">
      <div class="hero-inner">
        <div class="hero-top">
          <div class="hero-copy">
            <p class="eyebrow">Open-source products &middot; For governments and their partners</p>
            <h1 id="hero-title">Prove facts from registries without sharing the records.</h1>
            <p class="hero-thesis">
              Registry Stack helps public institutions expose protected registry APIs and return
              governed evidence, while source records stay with the authority that owns them.
            </p>
            <p class="hero-lead">
              Start with the registry you already have. Add a governed surface in front of it.
              Let approved services receive the answer they are allowed to receive: a protected
              read, a minimized fact, a credential, a redacted result, or a stable denial.
            </p>
            <div class="hero-actions" aria-label="Primary actions">
              <a class="button button-primary" href="/solutions/evidence-gateway/">Explore Evidence Gateway</a>
              <a class="button button-secondary" href="/solutions/protected-registry-apis/">Expose a registry safely</a>
            </div>
            <p class="hero-note">
              Prefer to see it first? The <a href="https://lab.registrystack.org/">hosted lab</a>
              runs on synthetic data and issues a signed proof into a wallet.
            </p>
          </div>

          <div class="hero-figure" aria-hidden="true">
            <div class="hero-card-wrap">
              <HeroAnswerCard answers={heroAnswers} />
              <div class="hero-seal"><RegistrySeal size={110} /></div>
            </div>
          </div>
        </div>

        <div class="hero-proof-grid" aria-label="Why this is adoptable">
          {heroReasons.map((reason) => (
            <article>
              <h2>{reason.label}</h2>
              <p>{reason.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="solutions" aria-labelledby="solutions-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow"><span class="reg-no">No. 01</span> &middot; Choose the path</p>
          <h2 id="solutions-title">Two ways to make registries usable without over-sharing records.</h2>
          <p>
            Start from the outcome you need. Registry Stack keeps the solution pattern separate
            from the products underneath it, so the first conversation stays clear.
          </p>
        </div>
        <div class="home-solution-grid">
          {solutions.map((solution) => (
            <article class="home-solution-card">
              <p class="eyebrow">{solution.eyebrow}</p>
              <h3>{solution.title}</h3>
              <p>{solution.body}</p>
              <ul>
                {solution.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
              <a class="inline-cta" href={solution.href}>{solution.cta} &rarr;</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-muted" id="products" aria-labelledby="products-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow"><span class="reg-no">No. 02</span> &middot; The products underneath</p>
          <h2 id="products-title">Three components, each with a narrow job.</h2>
          <p>
            Use one product on its own, or compose them when a deployment needs protected APIs,
            metadata, evidence decisions, and credential issuance together.
          </p>
        </div>
        <div class="home-product-strip">
          {products.map((product) => (
            <article>
              <p class="product-role">{product.role}</p>
              <h3>{product.title}</h3>
              <p>{product.body}</p>
              <a class="inline-cta" href={product.href}>Open {product.title} &rarr;</a>
            </article>
          ))}
        </div>
        <div class="centered-action">
          <a class="inline-cta" href="/use-cases/">See example questions and bounded answers &rarr;</a>
        </div>
      </div>
    </section>

    <section class="proof-band" id="built-in-the-open" aria-labelledby="proof-title">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Built in the open</p>
          <h2 id="proof-title">Standards-based, running live in the lab.</h2>
          <p>
            The homepage gives you the routes in. The proof sits in the product repos, the docs,
            and the hosted lab running on synthetic data.
          </p>
        </div>
        <div class="proof-grid">
          {proofPoints.map((point) => (
            <article>
              <h3>{point.title}</h3>
              <p>{point.body}</p>
              <p class="proof-fact">{point.fact}</p>
            </article>
          ))}
        </div>
        <div class="proof-partners" aria-label="Platforms Registry Stack works alongside">
          <span>Works alongside</span>
          <ul class="partner-logos">
            {worksAlongside.map((item) => (
              <li>
                <img src={item.src} alt={item.name} width={item.width} height={item.height} loading="lazy" />
              </li>
            ))}
          </ul>
        </div>
        <div class="proof-links">
          <a href="https://lab.registrystack.org/">Try the live demo &rarr;</a>
          <a href="/pilot/">What a pilot looks like &rarr;</a>
          <a href="/ecosystem/">How Registry Stack fits the ecosystem &rarr;</a>
        </div>
      </div>
    </section>

    <section class="final-cta" aria-labelledby="final-title">
      <div class="section-inner">
        <p class="pill">Start small</p>
        <h2 id="final-title">Start with one registry, one evidence need, and one governed service surface.</h2>
        <div class="hero-actions">
          <a class="button button-primary" href="/solutions/evidence-gateway/">Explore Evidence Gateway</a>
          <a class="button button-secondary" href="/solutions/protected-registry-apis/">See Protected Registry APIs</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
