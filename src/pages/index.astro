---
import Base from '../layouts/Base.astro';
import HeroAnswerCard from '../components/HeroAnswerCard.astro';
import HarnessDiagram from '../components/HarnessDiagram.astro';
import RegistrySeal from '../components/RegistrySeal.astro';

const pageTitle = 'Registry Stack | Prove facts from registries without sharing the records';
const pageDescription =
  'Registry Stack is three open-source products that let public services prove facts from existing registries: signed answers and credentials instead of copies of records.';

const heroReasons = [
  {
    label: 'Public service delivery',
    body: 'Help people and businesses get services without repeatedly proving facts government already knows.',
  },
  {
    label: 'Trust and safeguards',
    body: 'Records never leave the registry that owns them. Every answer is scoped to a stated purpose, signed, and recorded in an audit trail reviewers can read.',
  },
  {
    label: 'Practical path to scale',
    body: 'Start with one registry and one question, even a spreadsheet, and add services one at a time. No replatforming required first.',
  },
];

const useCases = [
  {
    domain: 'Civil registration',
    evidenceType: 'Credential',
    question: 'Is this person alive?',
    evidence: 'Issue a signed proof-of-life the person can hold and present.',
    notShared: 'Do not disclose the full civil-registration record.',
    output: 'Alive · proof of life',
  },
  {
    domain: 'Social protection',
    evidenceType: 'Decision',
    question: 'Is this household eligible?',
    evidence: 'Return an eligibility decision for the benefit or service.',
    notShared: 'Do not expose the household case file.',
    output: 'Eligible',
  },
  {
    domain: 'Business registry',
    evidenceType: 'Status',
    question: 'Is this supplier actively registered?',
    evidence: 'Return active registration status.',
    notShared: 'Do not disclose filing history or broader ownership data.',
    output: 'Active',
  },
  {
    domain: 'Farmer registry',
    evidenceType: 'Bounded value set',
    question: 'Is this a registered farmer, and what is the farm size?',
    evidence: 'Confirm registration and return farm size (for example, 2.5 ha).',
    notShared: 'Do not expose plot location, household roster, crop history, or financial records.',
    output: 'Registered farmer · 2.5 ha',
  },
];

// The hero card loops through the same answers shown in the use-cases grid, so
// the two can never drift apart.
const heroAnswers = useCases.map((item) => ({
  domain: item.domain,
  question: item.question,
  answer: item.output,
}));

// Neighbor platforms shown as monochrome marks. Display sizes are tuned per
// logo for visual parity, not taken from the source files.
const worksAlongside = [
  { name: 'OpenCRVS', src: '/logos/opencrvs.svg', width: 128, height: 24 },
  { name: 'OpenSPP', src: '/logos/openspp.svg', width: 114, height: 24 },
  { name: 'DHIS2', src: '/logos/dhis2.svg', width: 92, height: 28 },
  { name: 'MOSIP', src: '/logos/mosip.png', width: 75, height: 34 },
  { name: 'OpenFn', src: '/logos/openfn.png', width: 81, height: 30 },
];

const proofPoints = [
  {
    title: 'Open source, end to end',
    body: 'All three products are open source. Inspect the code, run them on your own infrastructure, and keep every safeguard auditable.',
    fact: 'No license fees, no vendor gate',
  },
  {
    title: 'A demo you can use right now',
    body: 'The hosted lab issues a real signed proof to a wallet in minutes, on synthetic data, and runs live integrations with OpenCRVS, DHIS2, MOSIP eSignet, and OpenFn. What this site claims, the demo shows.',
    fact: 'lab.registrystack.org',
  },
  {
    title: 'The standards wallets and catalogs speak',
    body: 'Credentials issue in the formats the European Digital Identity Wallet ecosystem uses, catalogs render to DCAT-AP, and registry sync follows SP-DCI. Built by contributors who help write the GovStack and DCI standards.',
    fact: 'SD-JWT VC · OpenID4VCI · no lock-in',
  },
];
---

<Base title={pageTitle} description={pageDescription}>
  <header class="site-header">
    <a class="brand" href="/" aria-label="Registry Stack home">
      <span class="brand-mark" aria-hidden="true">RS</span>
      <span>Registry Stack</span>
    </a>
    <nav class="top-nav" aria-label="Main navigation">
      <details class="nav-products">
        <summary>Products</summary>
        <div class="nav-products-panel">
          <a href="/notary/">
            <span class="nav-product-name">Registry Notary <span class="nav-product-role">Verify</span></span>
            <span class="nav-product-blurb">Signed answers and wallet credentials</span>
          </a>
          <a href="/relay/">
            <span class="nav-product-name">Registry Relay <span class="nav-product-role">Expose</span></span>
            <span class="nav-product-blurb">Protected APIs over existing files and tables</span>
          </a>
          <a href="/manifest/">
            <span class="nav-product-name">Registry Manifest <span class="nav-product-role">Describe</span></span>
            <span class="nav-product-blurb">Portable standards-facing metadata</span>
          </a>
        </div>
      </details>
      <a href="/why/">Why it matters</a>
      <a href="/use-cases/">Use cases</a>
      <a href="/ai/">AI</a>
      <a class="nav-emphasis" href="https://docs.registrystack.org/">Read the docs</a>
    </nav>
  </header>

  <main>
    <section class="hero hero-cover" aria-labelledby="hero-title">
      <div class="hero-inner">
        <div class="hero-top">
          <div class="hero-copy">
            <p class="eyebrow">Open source &middot; For governments and their partners</p>
            <h1 id="hero-title">Prove facts from registries without sharing the records.</h1>
            <p class="hero-lead">
              Registry Stack turns the registries a government already holds, from spreadsheets to
              source systems, into services that answer questions and issue signed proofs. A
              pensioner proves they are alive without a trip to the counter; the registry answers
              without handing over its records.
            </p>
            <div class="hero-actions" aria-label="Primary actions">
              <a class="button button-primary" href="https://lab.registrystack.org/">Try the live demo</a>
              <a class="button button-secondary" href="mailto:jeremi@joslin.fr?subject=Registry%20Stack%20pilot%20discussion">Discuss a pilot</a>
            </div>
            <p class="hero-note">
              The lab runs on synthetic data. No install, no account: receive a signed proof in a
              hosted wallet within minutes.
            </p>
          </div>

          <div class="hero-figure" aria-hidden="true">
            <div class="hero-card-wrap">
              <HeroAnswerCard answers={heroAnswers} />
              <div class="hero-seal"><RegistrySeal size={110} /></div>
            </div>
          </div>
        </div>

        <div class="hero-proof-grid" aria-label="Why this is adoptable">
          {heroReasons.map((reason) => (
            <article>
              <h2>{reason.label}</h2>
              <p>{reason.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="partner-strip" aria-label="Platforms Registry Stack works alongside">
      <div class="partner-strip-inner">
        <span>Works alongside</span>
        <ul class="partner-logos">
          {worksAlongside.map((item) => (
            <li>
              <img src={item.src} alt={item.name} width={item.width} height={item.height} loading="lazy" />
            </li>
          ))}
        </ul>
        <a class="inline-cta" href="/ecosystem/">How it fits &rarr;</a>
      </div>
    </section>

    <section class="claim-band" id="why-it-matters" aria-labelledby="why-title">
      <div class="section-inner split">
        <div class="section-heading compact">
          <p class="pill">Why it matters</p>
          <h2 id="why-title">The answers already exist. Services just cannot ask for them yet.</h2>
        </div>
        <div class="claim-body">
          <p>
            Governments already hold the data for faster, fairer services. What is missing is
            rarely the data: it is a safe way to ask. Who may ask, what answer comes back, what
            stays private, and how use is reviewed. Registry Stack supplies that asking layer:
            faster for people, safer for registries, simpler for programs.
          </p>
          <a class="inline-cta" href="/why/">See the recurring registry problems &rarr;</a>
        </div>
      </div>
    </section>

    <section class="section section-muted" id="products" aria-labelledby="products-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow"><span class="reg-no">No. 01</span> &middot; Where you start</p>
          <h2 id="products-title">Start from the problem on your desk.</h2>
          <p>
            Each situation below ends in one product. Every product is open source, runs on its
            own, and has a narrow job: adopt one, or compose them.
          </p>
        </div>
        <div class="product-grid">
          <article class="product-card">
            <h3 class="door-situation">&ldquo;Services keep asking us to send the whole record.&rdquo;</h3>
            <p>
              Answer the one question instead, with proof: a signed yes or no, a bounded value,
              or a credential the person can carry in a wallet. The record itself never leaves
              the registry.
            </p>
            <div class="product-artifact" aria-hidden="true">
              <span class="artifact-title">Proof of life</span>
              <span class="artifact-meta">Civil registry &middot; signed &middot; valid 10 minutes</span>
              <span class="artifact-meta">Held in the citizen&rsquo;s wallet &middot; shows only: alive</span>
            </div>
            <a class="inline-cta" href="/notary/">That&rsquo;s Registry Notary &rarr;</a>
          </article>
          <article class="product-card">
            <h3 class="door-situation">&ldquo;Our registry lives in a spreadsheet someone emails around.&rdquo;</h3>
            <p>
              Serve the source you already have, a spreadsheet, CSV, Parquet file, or database,
              as a protected, read-only API with access rules and audit built in. Nothing
              migrates.
            </p>
            <div class="product-artifact" aria-hidden="true">
              <div class="artifact-flow">
                <span class="artifact-chip">household-register.xlsx</span>
                <span class="artifact-arrow">&rarr;</span>
                <span class="artifact-chip artifact-chip-strong">protected registry API</span>
              </div>
              <span class="artifact-meta">Read-only &middot; scoped fields &middot; every request audited</span>
            </div>
            <a class="inline-cta" href="/relay/">That&rsquo;s Registry Relay &rarr;</a>
          </article>
          <article class="product-card">
            <h3 class="door-situation">&ldquo;Partners cannot tell what our registry holds, or what the fields mean.&rdquo;</h3>
            <p>
              Describe the registry once in a portable metadata file, validated and rendered into
              the standard formats catalogs and partners expect. Works as plain static files,
              without adopting anything else.
            </p>
            <div class="product-artifact" aria-hidden="true">
              <div class="artifact-flow">
                <span class="artifact-chip">metadata.yaml</span>
                <span class="artifact-arrow">&rarr;</span>
                <span class="artifact-chip">DCAT-AP</span>
                <span class="artifact-chip">SHACL</span>
                <span class="artifact-chip">JSON Schema</span>
              </div>
              <span class="artifact-meta">One description, rendered into the formats partners expect</span>
            </div>
            <a class="inline-cta" href="/manifest/">That&rsquo;s Registry Manifest &rarr;</a>
          </article>
        </div>
        <p class="door-aside">
          On the other side of the counter, running the program that needs the answers?
          <a class="inline-cta" href="/use-cases/">See what a minimized answer looks like &rarr;</a>
        </p>
      </div>
    </section>

    <section class="section" id="stack" aria-labelledby="stack-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow"><span class="reg-no">No. 02</span> &middot; The operating model</p>
          <h2 id="stack-title">A governance layer between registries and public services.</h2>
          <p>
            A governed path from source data to a service answer, with a record of every
            trust-critical request.
          </p>
        </div>
        <HarnessDiagram />
      </div>
    </section>

    <section class="section section-muted" id="use-cases" aria-labelledby="use-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow"><span class="reg-no">No. 03</span> &middot; Use cases</p>
          <h2 id="use-title">Ask for the evidence a service needs, not the whole record.</h2>
          <p>
            Each starting point is small enough for a pilot.
          </p>
        </div>
        <div class="use-case-grid">
          {useCases.map((item) => (
            <article class="use-case">
              <p class="use-case-domain">{item.domain}</p>
              <h3>{item.question}</h3>
              <div class="use-case-result">
                <span class="evidence-type">{item.evidenceType}</span>
                <span class="use-case-output">{item.output}</span>
              </div>
              <div class="use-case-field">
                <p class="use-case-label">Evidence returned</p>
                <p class="use-case-text">{item.evidence}</p>
              </div>
              <div class="use-case-field">
                <p class="use-case-label">Record not over-shared</p>
                <p class="use-case-text">{item.notShared}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="centered-action">
          <a class="inline-cta" href="/use-cases/">See the full scenario gallery &rarr;</a>
        </div>
      </div>
    </section>

    <section class="proof-band" id="built-in-the-open" aria-labelledby="proof-title">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Built in the open</p>
          <h2 id="proof-title">Open source, on open standards, with a demo you can use today.</h2>
          <p>
            Public services are converging on the once-only principle: people should not have to
            prove the same fact twice. Registry Stack is built for that direction.
          </p>
        </div>
        <div class="proof-grid">
          {proofPoints.map((point) => (
            <article>
              <h3>{point.title}</h3>
              <p>{point.body}</p>
              <p class="proof-fact">{point.fact}</p>
            </article>
          ))}
        </div>
        <div class="proof-links">
          <a href="/ai/">Give AI agents answers, not records &rarr;</a>
          <a href="/ecosystem/">How Registry Stack fits the ecosystem &rarr;</a>
        </div>
      </div>
    </section>

    <section class="final-cta" aria-labelledby="final-title">
      <div class="section-inner">
        <p class="pill">Start small</p>
        <h2 id="final-title">Start with one registry, one evidence need, and one governed service surface.</h2>
        <div class="hero-actions">
          <a class="button button-primary" href="https://lab.registrystack.org/">Try the live demo</a>
          <a class="button button-secondary" href="mailto:jeremi@joslin.fr?subject=Registry%20Stack%20pilot%20discussion">Discuss a pilot</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="site-footer-inner">
      <div>
        <strong>Registry Stack</strong>
        <p>Open-source infrastructure that lets public registries answer questions, issue proofs, and keep their records.</p>
      </div>
      <nav aria-label="Footer links">
        <a href="/notary/">Registry Notary</a>
        <a href="/relay/">Registry Relay</a>
        <a href="/manifest/">Registry Manifest</a>
        <a href="/ecosystem/">Ecosystem</a>
        <a href="https://docs.registrystack.org/">Docs</a>
        <a href="https://lab.registrystack.org/">Live demo</a>
      </nav>
    </div>
  </footer>
</Base>
