---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import HeroAnswerCard from '../components/HeroAnswerCard.astro';
import RegistrySeal from '../components/RegistrySeal.astro';

const pageTitle = 'Registry Stack | Governed registry services and trusted evidence';
const pageDescription =
  'Registry Stack lets public institutions open registries safely and share proof of a fact, without handing over the underlying records.';

const heroReasons = [
  {
    label: 'Answer, do not hand over',
    body: 'A service receives the one fact it needs, a yes or no, a status, or a credential, while the full record stays with the registry that owns it.',
  },
  {
    label: 'Safe on every request',
    body: 'Who may ask, for what purpose, and what they get back are checked on every request, and each one leaves an audit record a reviewer can read.',
  },
  {
    label: 'Start from what you have',
    body: 'Put a governed surface in front of the registry you already run, a spreadsheet, a database, or a domain platform, with no source-data migration required.',
  },
];

const heroAnswers = [
  {
    domain: 'Civil registration',
    question: 'Which age band applies to this person?',
    answer: 'Age band · 18-64',
  },
  {
    domain: 'Social protection',
    question: 'Is this household enrolled?',
    answer: 'Enrolled household',
  },
  {
    domain: 'Business registry',
    question: 'Is this supplier actively registered?',
    answer: 'Active',
  },
  {
    domain: 'Farmer registry',
    question: 'Is this a registered farmer, and what is the farm size?',
    answer: 'Registered farmer · 2.5 ha',
  },
];

const solutions = [
  {
    eyebrow: 'Share evidence, not records',
    title: 'Evidence Gateway',
    body:
      'Use this when a service needs proof of a fact, a yes or no, a status, or a credential, but should never receive the underlying record.',
    href: '/solutions/evidence-gateway/',
    cta: 'See how Evidence Gateway works',
    points: [
      'Every request is checked for who is asking and why before any answer is returned.',
      'The answer carries its own freshness, redaction, and audit trail.',
    ],
  },
  {
    eyebrow: 'Open a registry safely',
    title: 'Protected Registry APIs',
    body:
      'Use this when a registry already exists, in a file, a database, or a legacy system, and partners need a safe, read-only way to consult it.',
    href: '/solutions/protected-registry-apis/',
    cta: 'See how Protected Registry APIs work',
    points: [
      'Approved services get scoped routes, not a copy of the file or a database login.',
      'Every read is limited to agreed fields and recorded in the audit trail.',
    ],
  },
];

const products = [
  {
    title: 'Registry Notary',
    role: 'Verify',
    body: 'Answers a precise question against a registry and returns a configured proof or a wallet credential.',
    href: '/notary/',
  },
  {
    title: 'Registry Relay',
    role: 'Expose',
    body: 'Serves a protected, read-only API over the files and tables a registry already lives in.',
    href: '/relay/',
  },
  {
    title: 'Registry Manifest',
    role: 'Describe',
    body: 'Publishes a registry’s metadata, policies, and schemas in the standard formats partners read.',
    href: '/manifest/',
  },
];

// Neighbor platforms shown as monochrome marks. Display sizes are tuned per
// logo for visual parity, not taken from the source files.
const worksAlongside = [
  { name: 'OpenCRVS', src: '/logos/opencrvs.svg', width: 128, height: 24 },
  { name: 'OpenSPP', src: '/logos/openspp.svg', width: 114, height: 24 },
  { name: 'DHIS2', src: '/logos/dhis2.svg', width: 92, height: 28 },
  { name: 'HL7 FHIR', src: '/logos/fhir.svg', width: 92, height: 30 },
  { name: 'MOSIP', src: '/logos/mosip.png', width: 75, height: 34 },
  { name: 'OpenFn', src: '/logos/openfn.png', width: 81, height: 30 },
];

const proofPoints = [
  {
    title: 'Products with narrow jobs',
    body: 'Inspect the code, run the pieces on your own infrastructure, and compose only the surfaces a deployment needs.',
    fact: 'No product license fees, no vendor gate',
  },
  {
    title: 'A live lab you can use now',
    body: 'The hosted lab issues a configured proof to a wallet, on synthetic data, and runs integrations with OpenCRVS, DHIS2, MOSIP eSignet, and OpenFn.',
    fact: 'lab.registrystack.org',
  },
  {
    title: 'Standards-shaped outputs',
    body: 'Credentials issue as SD-JWT VC over OpenID4VCI, catalogs render to DCAT-AP, and registry sync follows SP-DCI where that pattern fits.',
    fact: 'SD-JWT VC · OpenID4VCI · no lock-in',
  },
];
---

<Base title={pageTitle} description={pageDescription}>
  <SiteHeader />

  <main>
    <section class="hero hero-cover" aria-labelledby="hero-title">
      <div class="hero-inner">
        <div class="hero-top">
          <div class="hero-copy">
            <p class="eyebrow">Open-source products &middot; For governments and their partners</p>
            <h1 id="hero-title">Prove facts from registries without sharing the records.</h1>
            <p class="hero-thesis">
              Registry Stack lets the registries a government already runs answer questions and
              share proof, while the underlying records stay with the authority that owns them.
            </p>
            <div class="hero-actions" aria-label="Primary actions">
              <a class="button button-primary" href="/solutions/evidence-gateway/">Share evidence, not records</a>
              <a class="button button-secondary" href="/solutions/protected-registry-apis/">Open a registry safely</a>
            </div>
            <p class="hero-note">
              Prefer to see it first? The <a href="https://lab.registrystack.org/">hosted lab</a>
              runs on synthetic data and issues a configured proof into a wallet.
            </p>
          </div>

          <div class="hero-figure" aria-hidden="true">
            <div class="hero-card-wrap">
              <HeroAnswerCard answers={heroAnswers} />
              <div class="hero-seal"><RegistrySeal size={110} /></div>
            </div>
          </div>
        </div>

        <div class="hero-proof-grid" aria-label="Why this is adoptable">
          {heroReasons.map((reason) => (
            <article>
              <h2>{reason.label}</h2>
              <p>{reason.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="solutions" aria-labelledby="solutions-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow"><span class="reg-no">No. 01</span> &middot; Choose the path</p>
          <h2 id="solutions-title">Two ways to make registries usable without over-sharing records.</h2>
          <p>
            Start from the outcome you need. Registry Stack keeps the solution you choose separate
            from the products that deliver it, so the first conversation stays about outcomes.
          </p>
        </div>
        <div class="home-solution-grid">
          {solutions.map((solution) => (
            <article class="home-solution-card">
              <p class="eyebrow">{solution.eyebrow}</p>
              <h3>{solution.title}</h3>
              <p>{solution.body}</p>
              <ul>
                {solution.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
              <a class="inline-cta" href={solution.href}>{solution.cta} &rarr;</a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-muted" id="products" aria-labelledby="products-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow"><span class="reg-no">No. 02</span> &middot; How it is built</p>
          <h2 id="products-title">Together, the two solutions are built from three open-source products.</h2>
          <p>
            Each product does one narrow job. A solution uses one on its own, or composes them,
            so a deployment adopts only the pieces it actually needs.
          </p>
        </div>
        <div class="home-product-strip">
          {products.map((product) => (
            <article>
              <p class="product-role">{product.role}</p>
              <h3>{product.title}</h3>
              <p>{product.body}</p>
              <a class="inline-cta" href={product.href}>Open {product.title} &rarr;</a>
            </article>
          ))}
        </div>
        <div class="centered-action">
          <a class="inline-cta" href="/use-cases/">See example questions and bounded answers &rarr;</a>
        </div>
      </div>
    </section>

    <section class="proof-band" id="built-in-the-open" aria-labelledby="proof-title">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Built in the open</p>
          <h2 id="proof-title">Standards-based, running live in the lab.</h2>
          <p>
            The homepage gives you the routes in. The proof sits in the product repos, the docs,
            and the hosted lab running on synthetic data.
          </p>
        </div>
        <div class="proof-grid">
          {proofPoints.map((point) => (
            <article>
              <h3>{point.title}</h3>
              <p>{point.body}</p>
              <p class="proof-fact">{point.fact}</p>
            </article>
          ))}
        </div>
        <div class="proof-partners" aria-label="Platforms Registry Stack works alongside">
          <span>Works alongside</span>
          <ul class="partner-logos">
            {worksAlongside.map((item) => (
              <li>
                <img src={item.src} alt={item.name} width={item.width} height={item.height} loading="lazy" />
              </li>
            ))}
          </ul>
        </div>
        <div class="proof-links">
          <a href="https://lab.registrystack.org/">Try the live demo &rarr;</a>
          <a href="/pilot/">What a pilot looks like &rarr;</a>
          <a href="/ecosystem/">How Registry Stack fits the ecosystem &rarr;</a>
        </div>
      </div>
    </section>

    <section class="final-cta" aria-labelledby="final-title">
      <div class="section-inner">
        <p class="pill">Start small</p>
        <h2 id="final-title">Start with one registry, one evidence need, and one governed service surface.</h2>
        <div class="hero-actions">
          <a class="button button-primary" href="/solutions/evidence-gateway/">Share evidence, not records</a>
          <a class="button button-secondary" href="/solutions/protected-registry-apis/">Open a registry safely</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</Base>
