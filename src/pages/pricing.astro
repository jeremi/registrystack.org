---
import Base from '../layouts/Base.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import DocsHandoff from '../components/DocsHandoff.astro';

const pageTitle = 'Pricing | Registry Stack';
const pageDescription =
  'Everything one registry needs is free forever. The subscription adds governance across many registry services. No per-citizen or per-credential fees, ever.';

const mailto = 'mailto:jeremi@joslin.fr?subject=Registry%20Stack%20package%20fit';

// Bands count managed registry services: one registry behind one governed
// answering point. Reference prices are for lower-middle-income deployments;
// see the income-tier note rendered above the cards.
const plans = [
  {
    name: 'Community',
    price: 'Free',
    term: 'forever',
    tagline: 'Everything a registry needs to answer safely, self-hosted.',
    includes: [
      'Registry Relay, Registry Notary, and Registry Manifest',
      'Signed builds, the posture and audit schemas, and the local self-check',
      'Registry Workbench: reports and evidence packs for a single service',
      'Community support. No registration, no callback.',
    ],
    cta: { label: 'Read the docs', href: 'https://docs.registrystack.org/', kind: 'secondary' },
  },
  {
    name: 'First registry',
    price: '$7,500',
    term: 'per year',
    tagline: 'One registry under management, with packaged support behind it.',
    featured: true,
    flag: 'Most programs start here',
    includes: [
      'Up to 2 managed registry services in one environment',
      'Inventory, health, and posture history for the services under management',
      'An evidence pack a reviewer, an auditor, or a funder can read',
      'Business-hours maintainer support included in the package',
    ],
    cta: { label: 'Request scope confirmation', href: null, kind: 'primary' },
  },
  {
    name: 'Program',
    price: '$25,000',
    term: 'per year',
    tagline: 'Your program’s registries under one governance discipline.',
    includes: [
      'Up to 6 managed registry services across 3 environments',
      'Findings and exceptions: time-bounded, owned, revocable decisions on record',
      'Audit continuity tracked across every service, with evidence packs to match',
      'A browser console for governance decisions, and priority support',
    ],
    cta: { label: 'Check package fit', href: null, kind: 'secondary' },
  },
];

const scalePlans = [
  {
    name: 'National',
    body: 'For programs that plug into a government’s identity, audit, and security estate, with longer retention and service-level commitments. Up to 15 managed registry services, confirmed against a published annual band.',
  },
  {
    name: 'Country membership',
    body: 'One flat annual agreement covering unlimited managed registry services across a government: sovereignty packaging, a named engineer, and a voice in the roadmap.',
  },
];
---

<Base title={pageTitle} description={pageDescription}>
  <SiteHeader current="pricing" />

  <main>
    <section class="hero" aria-labelledby="pricing-hero-title">
      <div class="hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Pricing</p>
          <h1 id="pricing-hero-title">Everything one registry needs is free. Forever.</h1>
          <p class="hero-lead">
            Registry Relay, Registry Notary, and Registry Manifest are open source,
            self-hosted, and complete: signed builds, a local self-check, no registration.
            Registry Trust Operations, the subscription, runs many registry services under
            one governance discipline, with maintainer support included in each package.
          </p>
          <div class="hero-actions" aria-label="Primary actions">
            <a class="button button-primary" href="https://docs.registrystack.org/">Start with the free tier</a>
            <a class="button button-secondary" href={mailto}>Check package fit</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-muted" aria-labelledby="never-title">
      <div class="section-inner">
        <div class="section-heading center">
          <p class="eyebrow">The pricing rule</p>
          <h2 id="never-title">What we never charge for.</h2>
        </div>
        <ul class="never-list">
          <li>Per citizen</li>
          <li>Per credential</li>
          <li>Per answer</li>
          <li>Per audit event</li>
          <li>Per read-only user</li>
        </ul>
        <p class="never-note">
          A price that meters answers taxes the success of a citizen service. Registry Stack
          is priced by the registry services under management, so a program that reaches
          twice as many people pays exactly the same.
        </p>
      </div>
    </section>

    <section class="section" aria-labelledby="plans-title">
      <div class="section-inner">
        <div class="section-heading">
          <p class="eyebrow">Plans</p>
          <h2 id="plans-title">Annual, per managed registry service, on your infrastructure.</h2>
          <p>
            A managed registry service is one registry behind one governed answering point.
            The figures shown are published package prices for lower-middle-income countries.
            The applicable package follows the World Bank income classification of the deploying
            country: lower for low-income and humanitarian deployments, higher for high-income
            ones. Nonprofits pay the low-income price.
          </p>
        </div>
        <div class="plan-grid">
          {plans.map((plan) => (
            <article class={plan.featured ? 'plan-card plan-card-featured' : 'plan-card'}>
              {plan.flag && <p class="plan-flag">{plan.flag}</p>}
              <h3>{plan.name}</h3>
              <p class="plan-price">{plan.price} <span>{plan.term}</span></p>
              <p class="plan-tagline">{plan.tagline}</p>
              <ul class="check-list">
                {plan.includes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
              <a
                class={`button button-${plan.cta.kind} plan-cta`}
                href={plan.cta.href ?? mailto}
              >
                {plan.cta.label}
              </a>
            </article>
          ))}
        </div>
        <div class="scale-grid">
          {scalePlans.map((plan) => (
            <article class="plan-card scale-card">
              <h3>{plan.name}</h3>
              <p class="plan-price plan-price-talk">Fixed annual band</p>
              <p class="plan-tagline">{plan.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-muted" aria-labelledby="direct-title">
      <div class="section-inner split">
        <div class="section-heading compact">
          <p class="eyebrow">Fixed packages</p>
          <h2 id="direct-title">Scope is confirmed before support starts.</h2>
        </div>
        <div class="direct-body">
          <p>
            Registry Stack support is packaged to keep procurement simple and avoid
            open-ended sales cycles. If your use case fits a listed package, the price is
            fixed. If it does not, we first confirm whether it belongs in a published support
            band before scheduling implementation time.
          </p>
          <a class="inline-cta" href={mailto}>Request scope confirmation &rarr;</a>
        </div>
      </div>
    </section>
  </main>

  <DocsHandoff
    eyebrow="For your technical team"
    heading="Everything in the free tier is in the docs. Evaluate it before requesting scope confirmation."
    primaryLabel="Read the docs"
    emphasis="pilot"
  />
  <SiteFooter />
</Base>

<style>
  .never-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    list-style: none;
    margin: 0 0 18px;
    padding: 0;
  }

  .never-list li {
    background: #ffffff;
    border: 1px solid var(--registry-rule);
    font-family: var(--registry-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    padding: 10px 16px;
  }

  /* Each metering model is struck from the register: a stamp-red cross, the
     mark an examiner puts against a rejected line item. */
  .never-list li::before {
    color: var(--registry-stamp);
    content: '✕ ' / '';
    font-weight: 700;
  }

  .never-note {
    color: var(--registry-body);
    margin: 0 auto;
    max-width: 620px;
    text-align: center;
  }

  /* Five shared rows (name, price, tagline, the includes list, CTA) so the
     prices sit on one line and the buttons on another, across all three
     cards, however long each tagline wraps. */
  .plan-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(5, auto);
  }

  .scale-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(3, auto);
    margin: 24px auto 0;
    max-width: 860px;
  }

  .plan-card {
    background: #ffffff;
    border: 1px solid var(--registry-rule);
    display: grid;
    grid-row: 1 / -1;
    grid-template-rows: subgrid;
    padding: 22px;
    position: relative;
    row-gap: 12px;
  }

  .plan-card h3 {
    margin: 0;
  }

  /* The recommended band carries the project's ink: blue border, the same
     hard offset shadow the product cards lift to on hover. */
  .plan-card-featured {
    border-color: var(--registry-blue);
    box-shadow: 4px 4px 0 rgba(23, 59, 122, 0.12);
  }

  /* A tab over the card's top rule, like a flag on a register page. */
  .plan-flag {
    background: var(--registry-blue);
    color: #ffffff;
    font-family: var(--registry-mono);
    font-size: 11px;
    font-weight: 700;
    left: 21px;
    letter-spacing: 0.06em;
    margin: 0;
    padding: 4px 10px;
    position: absolute;
    text-transform: uppercase;
    top: -12px;
  }

  .plan-cta {
    align-self: end;
    justify-content: center;
  }

  /* The fixed bands print as record slips, not catalogue items: ledger
     paper and a perforated edge, matching the product artifact cards. */
  .scale-card {
    background: var(--registry-paper);
    border: 1px dashed #c2cce0;
  }

  .plan-price {
    color: var(--registry-ink);
    font-family: var(--registry-mono);
    font-size: 24px;
    margin: 0;
  }

  .plan-price span {
    color: var(--registry-body);
    font-size: 13px;
    letter-spacing: 0.04em;
  }

  .plan-price-talk {
    font-size: 16px;
    letter-spacing: 0.02em;
  }

  .plan-tagline {
    color: var(--registry-body);
    margin: 0;
  }

  .direct-body p {
    color: var(--registry-body);
    margin: 0 0 14px;
  }

  /* Stacked cards lay out their own rows; the shared-row subgrid only earns
     its keep when the cards sit side by side. */
  @media (max-width: 900px) {
    .plan-grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
    }

    .plan-grid .plan-card {
      grid-row: auto;
      grid-template-rows: none;
    }
  }

  @media (max-width: 620px) {
    .scale-grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
    }

    .scale-card {
      grid-row: auto;
      grid-template-rows: none;
    }
  }
</style>
