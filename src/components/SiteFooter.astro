---
// Shared footer for every marketing page, including the homepage. The links are
// grouped into columns that mirror the site's information architecture, so the
// footer reads as a site map rather than one undifferentiated list.
const year = new Date().getFullYear();

const columns = [
  {
    title: 'Solutions',
    links: [
      { href: '/solutions/evidence-gateway/', label: 'Evidence Gateway' },
      { href: '/solutions/protected-registry-apis/', label: 'Protected Registry APIs' },
    ],
  },
  {
    title: 'Products',
    links: [
      { href: '/notary/', label: 'Registry Notary' },
      { href: '/relay/', label: 'Registry Relay' },
      { href: '/manifest/', label: 'Registry Manifest' },
    ],
  },
  {
    title: 'Learn',
    links: [
      { href: '/problem/', label: 'The problem' },
      { href: '/use-cases/', label: 'Use cases' },
      { href: '/ecosystem/', label: 'Ecosystem' },
      { href: '/ai/', label: 'AI in public services' },
      { href: '/security/', label: 'Security' },
      { href: '/faq/', label: 'FAQ' },
    ],
  },
  {
    title: 'Get started',
    links: [
      { href: '/pricing/', label: 'Pricing' },
      { href: '/pilot/', label: 'Start a pilot' },
      { href: 'https://docs.registrystack.org/', label: 'Documentation' },
      { href: 'https://lab.registrystack.org/', label: 'Live demo' },
    ],
  },
];
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <div class="footer-brand">
      <a class="footer-brand-name" href="/">Registry Stack</a>
      <p>Open-source products that let registry authorities answer questions, issue proofs, and keep their records.</p>
    </div>
    <nav class="footer-nav" aria-label="Footer">
      {columns.map((column) => (
        <div class="footer-col">
          <p class="footer-col-title">{column.title}</p>
          <ul>
            {column.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>
  <div class="site-footer-base">
    <p>&copy; {year} Registry Stack. Built in the open.</p>
    <p>Records stay with the authority that owns them.</p>
  </div>
</footer>
