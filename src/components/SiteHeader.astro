---
// Shared top navigation for every marketing page. The homepage keeps its own
// inline header so the single-page content contract can still assert on its
// source; this component carries the same brand mark and nav links for the
// deeper pages, with the current page marked aria-current.
const { current } = Astro.props;

const products = [
  { href: '/notary/', label: 'Registry Notary', role: 'Verify', blurb: 'Signed answers and wallet credentials', key: 'notary' },
  { href: '/relay/', label: 'Registry Relay', role: 'Expose', blurb: 'Protected APIs over existing files and tables', key: 'relay' },
  { href: '/manifest/', label: 'Registry Manifest', role: 'Describe', blurb: 'Portable standards-facing metadata', key: 'manifest' },
];

// Supporting reading folds into one disclosure so the bar itself stays the
// journey: problem, products, practice, price, pilot.
const practice = [
  { href: '/use-cases/', label: 'Use cases', blurb: 'Worked scenarios, question to signed answer', key: 'use-cases' },
  { href: '/ecosystem/', label: 'Ecosystem', blurb: 'Beside the platforms governments already run', key: 'ecosystem' },
  { href: '/ai/', label: 'AI in public services', blurb: 'Governed answers for human and AI askers', key: 'ai' },
];

const links = [
  { href: '/pricing/', label: 'Pricing', key: 'pricing' },
  { href: '/pilot/', label: 'Start a pilot', key: 'pilot' },
];

const onProductPage = products.some((product) => product.key === current);
const onPracticePage = practice.some((page) => page.key === current);
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Registry Stack home">
    <span class="brand-mark" aria-hidden="true">RS</span>
    <span>Registry Stack</span>
  </a>
  <nav class="top-nav" aria-label="Main navigation">
    <a href="/problem/" aria-current={current === 'problem' ? 'page' : undefined}>The problem</a>
    <details class="nav-group">
      <summary aria-current={onProductPage ? 'page' : undefined}>Products</summary>
      <div class="nav-group-panel">
        {products.map((product) => (
          <a href={product.href} aria-current={current === product.key ? 'page' : undefined}>
            <span class="nav-entry-name">{product.label} <span class="nav-entry-role">{product.role}</span></span>
            <span class="nav-entry-blurb">{product.blurb}</span>
          </a>
        ))}
      </div>
    </details>
    <details class="nav-group">
      <summary aria-current={onPracticePage ? 'page' : undefined}>In practice</summary>
      <div class="nav-group-panel">
        {practice.map((page) => (
          <a href={page.href} aria-current={current === page.key ? 'page' : undefined}>
            <span class="nav-entry-name">{page.label}</span>
            <span class="nav-entry-blurb">{page.blurb}</span>
          </a>
        ))}
      </div>
    </details>
    {links.map((link) => (
      <a href={link.href} aria-current={current === link.key ? 'page' : undefined}>{link.label}</a>
    ))}
    <a class="nav-emphasis" href="https://docs.registrystack.org/">Read the docs</a>
  </nav>
</header>
