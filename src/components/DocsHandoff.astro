---
// Shared closing CTA. Every marketing page ends with a clear handoff to the
// docs for the "how", plus a pilot-scope route. Copy can be tuned per page
// through props while keeping the band consistent.
interface Props {
  eyebrow?: string;
  heading?: string;
  primaryLabel?: string;
  primaryHref?: string;
  emphasis?: 'docs' | 'pilot';
}

const {
  eyebrow = 'Read the docs',
  heading = 'See how it works, end to end.',
  primaryLabel = 'Read the docs',
  primaryHref = 'https://docs.registrystack.org/',
  emphasis = 'docs',
} = Astro.props;
---

<section class="final-cta" aria-labelledby="handoff-title">
  <div class="section-inner">
    <p class="eyebrow">{eyebrow}</p>
    <h2 id="handoff-title">{heading}</h2>
    <div class="hero-actions">
      {emphasis === 'pilot' ? (
        <>
          <a class="button button-primary" href="mailto:jeremi@joslin.fr?subject=Registry%20Stack%20pilot%20scope">Request pilot scope</a>
          <a class="button button-secondary" href={primaryHref}>{primaryLabel}</a>
        </>
      ) : (
        <>
          <a class="button button-primary" href={primaryHref}>{primaryLabel}</a>
          <a class="button button-secondary" href="mailto:jeremi@joslin.fr?subject=Registry%20Stack%20pilot%20scope">Request pilot scope</a>
        </>
      )}
    </div>
  </div>
</section>
